---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Reviews from '../components/Reviews.astro';
import Contact from '../components/Contact.astro';
import CTABanner from '../components/CTABanner.astro';
import Footer from '../components/Footer.astro';
import Popup from '../components/Popup.astro';

const svgAttrs = 'xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"';

const services = [
  {
    imageUrl:
      'https://images.unsplash.com/photo-1585771724684-38269d6639fd?auto=format&fit=crop&q=80&w=800',
    icon: `<svg ${svgAttrs}><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/></svg>`,
    title: 'Détection de Fuites',
    description:
      "Nos spécialistes utilisent des technologies modernes pour identifier rapidement l'origine des fuites. Disponible 24h/24 et 7j/7, nous minimisons les temps d'arrêt et évitons des réparations coûteuses.",
  },
  {
    imageUrl:
      'https://images.unsplash.com/photo-1558618666-fcd25c85cd64?auto=format&fit=crop&q=80&w=800',
    icon: `<svg ${svgAttrs}><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
    title: 'Débouchage de Canalisations',
    description:
      'Nos experts utilisent des outils professionnels pour éliminer les obstructions causées par des débris, racines ou autres obstacles. Intervention rapide pour restaurer un écoulement normal.',
  },
  {
    imageUrl:
      'https://images.unsplash.com/photo-1504328345606-18bbc8c9d7d1?auto=format&fit=crop&q=80&w=800',
    icon: `<svg ${svgAttrs}><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>`,
    title: 'Chauffagiste',
    description:
      "Installation, entretien et réparation de tous types de systèmes de chauffage — chaudières, radiateurs, chauffe-eau. Nos techniciens certifiés interviennent avec soin pour votre confort optimal toute l'année.",
  },
  {
    imageUrl:
      'https://images.unsplash.com/photo-1581244277943-fe4a9c777189?auto=format&fit=crop&q=80&w=800',
    icon: `<svg ${svgAttrs}><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>`,
    title: 'Dépannage Plomberie en Urgence',
    description:
      "Fuite d'eau, canalisation bouchée ou panne soudaine — chaque minute compte. Notre équipe intervient rapidement 24h/7j pour diagnostiquer et résoudre efficacement votre problème.",
  },
  {
    imageUrl:
      'https://images.unsplash.com/photo-1607472586893-edb57bdc0e39?auto=format&fit=crop&q=80&w=800',
    icon: `<svg ${svgAttrs}><path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/></svg>`,
    title: 'Réparation de Tuyauterie',
    description:
      "Qu'il s'agisse de fuites, tuyaux rouillés ou joints défectueux, nous proposons des solutions adaptées. Réparations temporaires ou permanentes selon l'urgence pour prolonger la vie de votre réseau.",
  },
  {
    imageUrl:
      'https://images.unsplash.com/photo-1552321554-5fefe8c9ef14?auto=format&fit=crop&q=80&w=800',
    icon: `<svg ${svgAttrs}><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
    title: 'Installation de Systèmes Sanitaires',
    description:
      "Service complet d'installation — toilettes, lavabos, douches — garantissant qualité et conformité aux normes. Chaque installation est réalisée avec précision et notre équipe reste disponible pour la maintenance.",
  },
];

const delays = ['0s', '0.3s', '0.6s', '0.9s', '1.2s', '1.5s'];
---

<a href="tel:0189709634" class="sticky-btn">
  <span class="sticky-btn-pulse" aria-hidden="true"></span>
  Appel Gratuit — 01 89 70 96 34
</a>

<style>
  .sticky-btn {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 999;
    display: inline-flex;
    align-items: center;
    background: #dc2626;
    color: white;
    text-decoration: none;
    padding: 16px 32px;
    border-radius: 50px;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: 1px;
    box-shadow: 0 8px 24px rgba(220, 38, 38, 0.4);
    transition: transform 0.2s, box-shadow 0.2s;
    white-space: nowrap;
  }

  .sticky-btn-pulse {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #22c55e;
    margin-right: 8px;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%,
    100% {
      box-shadow: 0 0 0 0 rgba(34, 197, 94, 0.5);
    }
    50% {
      box-shadow: 0 0 0 7px rgba(34, 197, 94, 0);
    }
  }

  .sticky-btn:hover {
    transform: translateX(-50%) translateY(-2px);
    box-shadow: 0 12px 32px rgba(220, 38, 38, 0.5);
  }
</style>

<Layout>
  <Popup />
  <Navbar />
  <main>
    <div class="services-page">
      <h1 class="services-page-title">Nos Services</h1>
      <p class="services-page-subtitle">De la conception à la maintenance, nous livrons des résultats d'exception.</p>
      <div class="services-page-grid">
        {
          services.map((s, i) => (
            <article class="services-page-card" style={`animation-delay: ${delays[i]};`}>
              <img
                class="services-page-card-img"
                src={s.imageUrl}
                alt={s.title}
                width="800"
                height="200"
                loading="lazy"
                decoding="async"
              />
              <div class="services-page-card-icon" set:html={s.icon} />
              <h2 class="services-page-card-title">{s.title}</h2>
              <p class="services-page-card-desc">{s.description}</p>
            </article>
          ))
        }
      </div>
    </div>
    <Reviews id="avis" />
    <Contact id="contact" />
    <CTABanner />
    <Footer />
  </main>
</Layout>

<style>
  .services-page {
    position: relative;
    z-index: 1;
    padding: 120px 24px 160px;
  }

  .services-page-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(36px, 6vw, 64px);
    font-weight: 800;
    color: #ffffff;
    text-align: center;
    margin: 0 0 16px;
    line-height: 1.1;
  }

  .services-page-subtitle {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 15px;
    color: #94a3b8;
    text-align: center;
    margin: 0 auto 60px;
    max-width: 520px;
    line-height: 1.7;
  }

  .services-page-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 28px;
    max-width: 1100px;
    margin: 0 auto;
  }

  .services-page-card {
    background: #ffffff;
    border-radius: 20px;
    padding: 32px 28px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    animation: float 5s ease-in-out infinite;
  }

  .services-page-card-img {
    display: block;
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 12px;
    margin-bottom: 16px;
  }

  .services-page-card-icon {
    width: 48px;
    height: 48px;
    background: #eff6ff;
    border-radius: 12px;
    padding: 8px;
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .services-page-card-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 22px;
    font-weight: 700;
    color: #0f172a;
    margin: 0 0 10px;
    line-height: 1.25;
  }

  .services-page-card-desc {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 14px;
    color: #64748b;
    line-height: 1.75;
    margin: 0;
  }

  @keyframes float {
    0%,
    100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  @media (max-width: 768px) {
    .services-page-grid {
      grid-template-columns: 1fr;
    }

    .services-page-card {
      animation: none !important;
    }
  }
</style>
