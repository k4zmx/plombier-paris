---
import '../styles/global.css';
---
<!doctype html>
<html lang="fr">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="Plombier en urgence 24h/7 — Intervention rapide, dépannage et installation. Appelez maintenant." />
		<link rel="icon" type="image/x-icon" href="/favicon2.ico" />
		<link rel="apple-touch-icon" href="/favicon-64.png" />
		<title>Docteur Plomberie — Plombier Urgence 24h/7</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<!-- Non-render-blocking font load; display=swap is in the URL for FOUT prevention -->
		<link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Chelsea+Market&family=Inter:wght@400;500;600&display=swap" />
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Chelsea+Market&family=Inter:wght@400;500;600&display=swap" media="print" onload="this.media='all'" />
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@700;800&family=Chelsea+Market&family=Inter:wght@400;500;600&display=swap" /></noscript>
	</head>
	<body>
		<div class="bg-blobs">
			<div class="blob blob1"></div>
			<div class="blob blob2"></div>
			<div class="blob blob3"></div>
			<div class="blob blob4"></div>
		</div>
		<slot />
	</body>
</html>

<style is:global>
	*, *::before, *::after {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	html {
		scroll-behavior: smooth;
		/* overflow-x: hidden intentionally omitted — it breaks position: sticky in all browsers */
	}

	body {
		font-family: 'Inter', Arial, sans-serif;
		overflow-x: hidden;
		background-color: #1e293b;
	}

	h1, h2, h3 {
		font-family: 'Barlow Condensed', sans-serif;
	}

	.bg-blobs {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: 0;
		pointer-events: none;
		overflow: hidden;
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(80px);
		opacity: 0.25;
	}

	.blob1 {
		width: 500px;
		height: 500px;
		top: -100px;
		left: -100px;
		animation: blobMove 14s ease-in-out infinite, rgbBlob1 8s ease-in-out infinite;
	}

	.blob2 {
		width: 400px;
		height: 400px;
		top: 30%;
		right: -80px;
		animation: blobMove 18s ease-in-out 2s infinite, rgbBlob2 8s ease-in-out infinite;
	}

	.blob3 {
		width: 350px;
		height: 350px;
		bottom: 10%;
		left: 20%;
		animation: blobMove 16s ease-in-out 4s infinite, rgbBlob3 8s ease-in-out infinite;
	}

	.blob4 {
		width: 300px;
		height: 300px;
		bottom: -80px;
		right: 25%;
		animation: blobMove 20s ease-in-out 1s infinite, rgbBlob4 8s ease-in-out infinite;
	}

	@keyframes blobMove {
		0%,
		100% {
			transform: translate(0, 0) scale(1);
		}
		25% {
			transform: translate(30px, -40px) scale(1.05);
		}
		50% {
			transform: translate(-20px, 30px) scale(0.95);
		}
		75% {
			transform: translate(40px, 20px) scale(1.03);
		}
	}

	@keyframes rgbBlob1 {
		0%,
		100% {
			background-color: #1d4ed8;
		}
		33.33% {
			background-color: #22c55e;
		}
		66.66% {
			background-color: #a855f7;
		}
	}

	@keyframes rgbBlob2 {
		0%,
		100% {
			background-color: #dc2626;
		}
		33.33% {
			background-color: #1d4ed8;
		}
		66.66% {
			background-color: #f59e0b;
		}
	}

	@keyframes rgbBlob3 {
		0%,
		100% {
			background-color: #0ea5e9;
		}
		33.33% {
			background-color: #ec4899;
		}
		66.66% {
			background-color: #22c55e;
		}
	}

	@keyframes rgbBlob4 {
		0%,
		100% {
			background-color: #1d4ed8;
		}
		33.33% {
			background-color: #f59e0b;
		}
		66.66% {
			background-color: #dc2626;
		}
	}

	main, nav, header, footer, section {
		position: relative;
		z-index: 1;
	}

	@media (max-width: 768px) {
		/* Disable heavy blob animations on mobile */
		.blob {
			animation: none !important;
		}

		/* Push main content below the sticky navbar (~65px) */
		main {
			padding-top: 68px;
		}

		/* Prevent anchor targets from being hidden behind the sticky navbar */
		section[id] {
			scroll-margin-top: 72px;
		}

		/* Sticky CTA — centered pill, coordinate space stable because
		   overflow-x: hidden is on body (not html), so left: 50% resolves
		   correctly against the viewport width at all times. */
		.sticky-btn {
			left: 50%;
			right: auto;
			bottom: 20px;
			width: auto;
			transform: translateX(-50%);
			border-radius: 50px;
			padding: 14px 24px;
			font-size: 17px;
		}

		.sticky-btn:hover {
			transform: translateX(-50%) translateY(-2px);
		}
	}
</style>