---

<section class="tarifs" id="tarifs">
  <div class="tarifs-inner">

    <div class="tarifs-header">
      <h2>Nos Tarifs</h2>
      <p>Tarification transparente — devis détaillé avant chaque intervention.</p>
    </div>

    <div class="tarifs-grid">

      <!-- Table 1: Déplacements -->
      <div class="tarifs-card">
        <div class="tarifs-card-title-bar">
          <h3>Déplacements</h3>
        </div>
        <div class="tarifs-table-wrap">
          <table class="tarifs-table">
            <thead>
              <tr>
                <th scope="col">Prestation</th>
                <th scope="col">Semaine Jour<br /><span class="col-sub">8h – 18h</span></th>
                <th scope="col">Soir · WE Jour<br /><span class="col-sub">18h – 22h</span></th>
                <th scope="col">Soir · WE · Fériés<br /><span class="col-sub">22h – 8h</span></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Déplacement</td>
                <td class="price">39 €</td>
                <td class="price">59 €</td>
                <td class="price">89 €</td>
              </tr>
              <tr>
                <td>Devis / Diagnostic</td>
                <td class="price gratuit" colspan="3">Gratuit</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Table 2: Diagnostics & Recherches -->
      <div class="tarifs-card">
        <div class="tarifs-card-title-bar">
          <h3>Diagnostics &amp; Recherches</h3>
        </div>
        <div class="tarifs-table-wrap">
          <table class="tarifs-table">
            <thead>
              <tr>
                <th scope="col">Prestation</th>
                <th scope="col">Semaine Jour</th>
                <th scope="col">Soir · WE Jour</th>
                <th scope="col">Soir · WE · Fériés</th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Recherche fuite simple</td>
                <td class="price">289 €</td>
                <td class="price">329 €</td>
                <td class="price">389 €</td>
              </tr>
              <tr>
                <td>Diagnostic fuite de gaz</td>
                <td class="price">189 €</td>
                <td class="price">239 €</td>
                <td class="price">289 €</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

      <!-- Table 3: Interventions courantes -->
      <div class="tarifs-card tarifs-card--wide">
        <div class="tarifs-card-title-bar">
          <h3>Interventions courantes</h3>
        </div>
        <p class="tarifs-card-note">Prix hors déplacement — devis gratuit sur place avant tout travail.</p>
        <div class="tarifs-table-wrap">
          <table class="tarifs-table">
            <thead>
              <tr>
                <th scope="col">Intervention</th>
                <th scope="col">À partir de <span class="col-sub">(hors déplacement)</span></th>
              </tr>
            </thead>
            <tbody>
              <tr>
                <td>Débouchage WC / évier / lavabo</td>
                <td class="price">179 €</td>
              </tr>
              <tr>
                <td>Remplacement robinet</td>
                <td class="price">129 €</td>
              </tr>
            </tbody>
          </table>
        </div>
      </div>

    </div>

    <p class="tarifs-disclaimer">
      Tous les prix sont HT. Le déplacement s'ajoute au tarif de la prestation. Un devis détaillé vous est remis avant chaque intervention.
    </p>

  </div>
</section>

<style>
  .tarifs {
    position: relative;
    z-index: 1;
    padding: 80px 16px;
  }

  .tarifs-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  /* ── Section header ── */
  .tarifs-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .tarifs-header h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 800;
    color: #f1f5f9;
    margin: 0 0 12px;
    line-height: 1.15;
  }

  .tarifs-header p {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 15px;
    color: #94a3b8;
    margin: 0 auto;
    max-width: 480px;
    line-height: 1.7;
  }

  /* ── Card grid ── */
  .tarifs-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }

  .tarifs-card--wide {
    grid-column: 1 / -1;
  }

  /* ── Individual card ── */
  .tarifs-card {
    background: #ffffff;
    border-radius: 20px;
    padding: 28px 24px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    animation: float 5s ease-in-out infinite;
  }

  .tarifs-card:nth-child(2) {
    animation-delay: 0.4s;
  }

  .tarifs-card:nth-child(3) {
    animation-delay: 0.8s;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50%       { transform: translateY(-8px); }
  }

  /* ── Card header bar ── */
  .tarifs-card-title-bar {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
  }

  .tarifs-card-icon {
    font-size: 22px;
    line-height: 1;
  }

  .tarifs-card-title-bar h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(18px, 2.5vw, 22px);
    font-weight: 700;
    color: #0f172a;
    margin: 0;
    line-height: 1.2;
  }

  .tarifs-card-note {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 13px;
    color: #64748b;
    margin: -10px 0 18px;
    line-height: 1.5;
  }

  /* ── Table wrapper (enables horizontal scroll on small screens) ── */
  .tarifs-table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border-radius: 12px;
    border: 1px solid #e2e8f0;
  }

  /* ── Table ── */
  .tarifs-table {
    width: 100%;
    border-collapse: collapse;
    font-family: 'Inter', Arial, sans-serif;
    font-size: 14px;
    white-space: nowrap;
  }

  .tarifs-table thead tr {
    background: #1d4ed8;
  }

  .tarifs-table th {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #ffffff;
    text-align: center;
    padding: 12px 16px;
    line-height: 1.3;
    letter-spacing: 0.02em;
    border-right: 1px solid rgba(255, 255, 255, 0.15);
  }

  .tarifs-table th:first-child {
    text-align: left;
  }

  .tarifs-table th:last-child {
    border-right: none;
  }

  .col-sub {
    display: block;
    font-family: 'Inter', Arial, sans-serif;
    font-size: 11px;
    font-weight: 400;
    opacity: 0.8;
    margin-top: 2px;
  }

  .tarifs-table tbody tr {
    border-bottom: 1px solid #e2e8f0;
  }

  .tarifs-table tbody tr:last-child {
    border-bottom: none;
  }

  .tarifs-table tbody tr:nth-child(even) {
    background: #f8fafc;
  }

  .tarifs-table td {
    padding: 14px 16px;
    color: #334155;
    border-right: 1px solid #e2e8f0;
    vertical-align: middle;
  }

  .tarifs-table td:last-child {
    border-right: none;
  }

  .tarifs-table td:first-child {
    font-family: 'Inter', Arial, sans-serif;
    color: #0f172a;
    white-space: normal;
  }

  .price {
    text-align: center;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: #1d4ed8;
  }

  .gratuit {
    color: #16a34a;
    background: #f0fdf4;
    font-size: 15px;
  }

  /* ── Disclaimer ── */
  .tarifs-disclaimer {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 12px;
    color: #64748b;
    text-align: center;
    margin: 28px auto 0;
    max-width: 640px;
    line-height: 1.7;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .tarifs {
      padding: 60px 16px;
      margin-top: -32px;
      margin-bottom: -32px;
      width: 100%;
      box-sizing: border-box;
      overflow-x: hidden;
    }

    .tarifs-header h2,
    .tarifs-header p {
      padding: 0 4px;
      text-align: center;
    }

    .tarifs-grid {
      grid-template-columns: 1fr;
    }

    .tarifs-card--wide {
      grid-column: 1;
    }

    .tarifs-card {
      padding: 20px 16px;
      animation: none !important;
      width: 100%;
      box-sizing: border-box;
      overflow: hidden;
    }

    .tarifs-table-wrap {
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: thin;
      scrollbar-color: #1d4ed8 #e2e8f0;
    }

    .tarifs-table-wrap::-webkit-scrollbar {
      height: 6px;
    }

    .tarifs-table-wrap::-webkit-scrollbar-track {
      background: #e2e8f0;
      border-radius: 4px;
    }

    .tarifs-table-wrap::-webkit-scrollbar-thumb {
      background: #1d4ed8;
      border-radius: 4px;
    }

    .tarifs-table {
      font-size: 12px;
      white-space: nowrap;
    }

    .tarifs-table th {
      font-size: 11px;
      padding: 6px 8px;
      line-height: 1.2;
    }

    .col-sub {
      font-size: 10px;
    }

    .tarifs-table td {
      padding: 6px 8px;
    }

    /* First-column labels: keep on one line */
    .tarifs-table td:first-child {
      font-size: 11px;
      white-space: nowrap;
    }

    .price {
      font-size: 12px;
    }
  }
</style>
