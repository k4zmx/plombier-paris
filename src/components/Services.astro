<section class="services" id="services">
  <div class="services-inner">

    <div class="section-header">
      <h2>Nos Services</h2>
      <p>Des solutions rapides et durables pour tous vos problèmes de plomberie.</p>
    </div>

    <div class="services-grid">

      <div class="service-card service-card-hidden">
        <div class="service-card-inner">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 16.3c2.2 0 4-1.83 4-4.05 0-1.16-.57-2.26-1.71-3.19S7.29 6.75 7 5.3c-.29 1.45-1.14 2.84-2.29 3.76S3 11.1 3 12.25c0 2.22 1.8 4.05 4 4.05z"/><path d="M12.56 6.6A10.97 10.97 0 0 0 14 3.02c.5 2.5 2 4.9 4 6.5s3 3.5 3 5.5a6.98 6.98 0 0 1-11.91 4.97"/></svg>
          </div>
          <h3>Recherche de Fuite &amp; Réparation</h3>
          <p>Une fuite invisible ou un robinet qui goutte ? Nous localisons et réparons vos fuites d'eau rapidement pour éviter tout dégât des eaux.</p>
        </div>
      </div>

      <div class="service-card service-card-hidden">
        <div class="service-card-inner">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
          </div>
          <h3>Débouchage Canalisations</h3>
          <p>Évier, WC ou douche bouchés ? Nos techniciens utilisent un matériel haute pression pour dégager vos conduits efficacement.</p>
        </div>
      </div>

      <div class="service-card service-card-hidden">
        <div class="service-card-inner">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
          </div>
          <h3>Ballon d'eau chaude &amp; Chauffage</h3>
          <p>Installation, remplacement ou entretien de votre chauffe-eau. Profitez d'une eau chaude constante grâce à nos solutions performantes.</p>
        </div>
      </div>

      <div class="service-card service-card-hidden">
        <div class="service-card-inner">
          <div class="service-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#1d4ed8" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="8" height="4" x="8" y="2" rx="1" ry="1"/><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><path d="M12 11h4"/><path d="M12 16h4"/><path d="M8 11h.01"/><path d="M8 16h.01"/></svg>
          </div>
          <h3>Devis Gratuit &amp; Proximité</h3>
          <p>Artisan local intervenant 24h/24. Tarification transparente avec un devis détaillé avant chaque début de travaux.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  function initServiceCardsReveal() {
    const cards = document.querySelectorAll('.services .service-card');
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.remove('service-card-hidden');
          entry.target.classList.add('service-card-visible');
          observer.unobserve(entry.target);
        });
      },
      { root: null, threshold: 0.08, rootMargin: '0px 0px -20px 0px' }
    );

    cards.forEach((card) => observer.observe(card));
  }

  initServiceCardsReveal();
</script>

<style>
  .services {
    padding: 80px 16px;
    position: relative;
    z-index: 1;
  }

  .services-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-header h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 800;
    color: #f1f5f9;
    margin-bottom: 12px;
  }

  .section-header p {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 15px;
    color: #94a3b8;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .service-card {
    transition: transform 0.3s ease;
  }

  .service-card-hidden {
    opacity: 0;
    transform: translateY(30px);
  }

  .service-card-visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .service-card-visible:nth-child(1) { transition-delay: 0s; }
  .service-card-visible:nth-child(2) { transition-delay: 0.15s; }
  .service-card-visible:nth-child(3) { transition-delay: 0.3s; }
  .service-card-visible:nth-child(4) { transition-delay: 0.45s; }

  .service-card-inner {
    background: #ffffff;
    border-radius: 20px;
    padding: 28px 24px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    transition: box-shadow 0.3s ease;
    animation: float 5s ease-in-out infinite;
    height: 100%;
  }

  .service-card:nth-child(1) .service-card-inner { animation-delay: 0s; }
  .service-card:nth-child(2) .service-card-inner { animation-delay: 0.5s; }
  .service-card:nth-child(3) .service-card-inner { animation-delay: 1s; }
  .service-card:nth-child(4) .service-card-inner { animation-delay: 1.5s; }

  .service-card:hover { transform: translateY(-6px); }
  .service-card:hover .service-card-inner { box-shadow: 0 16px 48px rgba(0, 0, 0, 0.2); }

  .service-icon {
    width: 48px;
    height: 48px;
    background: #eff6ff;
    border-radius: 12px;
    padding: 8px;
    margin-bottom: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .service-card h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 10px;
  }

  .service-card p {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 14px;
    color: #64748b;
    line-height: 1.7;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  @media (max-width: 768px) {
    .services {
      padding: 60px 12px;
      margin-top: -32px;
      margin-bottom: -32px;
    }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .service-card-inner {
      padding: 24px 20px;
      animation: none !important;
    }

    /* Kill entrance animations — cards appear instantly */
    .service-card-hidden {
      opacity: 1 !important;
      transform: none !important;
    }

    .service-card-visible {
      transition: none !important;
    }

    /* No hover lift on touch */
    .service-card:hover {
      transform: none !important;
    }
  }
</style>