---

<section class="services" id="services">
  <div class="services-inner">

    <div class="section-header">
      <h2>Nos Services</h2>
      <p>Des solutions rapides et durables pour tous vos problèmes de plomberie.</p>
    </div>

    <div class="services-grid">

      <div class="service-card service-card-hidden">
        <div class="service-card-inner">
          <div class="service-icon">💧</div>
          <h3>Recherche de Fuite & Réparation</h3>
          <p>Une fuite invisible ou un robinet qui goutte ? Nous localisons et réparons vos fuites d'eau rapidement pour éviter tout dégât des eaux.</p>
        </div>
      </div>

      <div class="service-card service-card-hidden">
        <div class="service-card-inner">
          <div class="service-icon">🔧</div>
          <h3>Débouchage Canalisations</h3>
          <p>Évier, WC ou douche bouchés ? Nos techniciens utilisent un matériel haute pression pour dégager vos conduits efficacement.</p>
        </div>
      </div>

      <div class="service-card service-card-hidden">
        <div class="service-card-inner">
          <div class="service-icon">🔥</div>
          <h3>Ballon d'eau chaude & Chauffage</h3>
          <p>Installation, remplacement ou entretien de votre chauffe-eau. Profitez d'une eau chaude constante grâce à nos solutions performantes.</p>
        </div>
      </div>

      <div class="service-card service-card-hidden">
        <div class="service-card-inner">
          <div class="service-icon">📋</div>
          <h3>Devis Gratuit & Proximité</h3>
          <p>Artisan local intervenant 24h/24. Tarification transparente avec un devis détaillé avant chaque début de travaux.</p>
        </div>
      </div>

    </div>
  </div>
</section>

<script>
  function initServiceCardsReveal() {
    const cards = document.querySelectorAll('.services .service-card');
    if (!cards.length) return;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.remove('service-card-hidden');
          entry.target.classList.add('service-card-visible');
          observer.unobserve(entry.target);
        });
      },
      { root: null, threshold: 0.08, rootMargin: '0px 0px -20px 0px' }
    );

    cards.forEach((card) => observer.observe(card));
  }

  initServiceCardsReveal();
</script>

<style>
  .services {
    padding: 80px 16px;
    position: relative;
    z-index: 1;
  }

  .services-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .section-header h2 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(28px, 5vw, 52px);
    font-weight: 800;
    color: #f1f5f9;
    margin-bottom: 12px;
  }

  .section-header p {
    font-family: 'Chelsea Market', cursive;
    font-size: 15px;
    color: #94a3b8;
    max-width: 480px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .service-card {
    transition: transform 0.3s ease;
  }

  .service-card-hidden {
    opacity: 0;
    transform: translateY(30px);
  }

  .service-card-visible {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }

  .service-card-visible:nth-child(1) { transition-delay: 0s; }
  .service-card-visible:nth-child(2) { transition-delay: 0.15s; }
  .service-card-visible:nth-child(3) { transition-delay: 0.3s; }
  .service-card-visible:nth-child(4) { transition-delay: 0.45s; }

  .service-card-inner {
    background: #ffffff;
    border-radius: 20px;
    padding: 28px 24px;
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15);
    transition: box-shadow 0.3s ease;
    animation: float 5s ease-in-out infinite;
    height: 100%;
  }

  .service-card:nth-child(1) .service-card-inner { animation-delay: 0s; }
  .service-card:nth-child(2) .service-card-inner { animation-delay: 0.5s; }
  .service-card:nth-child(3) .service-card-inner { animation-delay: 1s; }
  .service-card:nth-child(4) .service-card-inner { animation-delay: 1.5s; }

  .service-card:hover { transform: translateY(-6px); }
  .service-card:hover .service-card-inner { box-shadow: 0 16px 48px rgba(0, 0, 0, 0.2); }

  .service-icon {
    font-size: 32px;
    margin-bottom: 14px;
  }

  .service-card h3 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 10px;
  }

  .service-card p {
    font-family: 'Chelsea Market', cursive;
    font-size: 14px;
    color: #64748b;
    line-height: 1.7;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  @media (max-width: 768px) {
    .services {
      padding: 60px 12px;
      margin-top: -32px;
      margin-bottom: -32px;
    }

    .services-grid {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .service-card-inner {
      padding: 24px 20px;
      animation: none !important;
    }

    /* Kill entrance animations — cards appear instantly */
    .service-card-hidden {
      opacity: 1 !important;
      transform: none !important;
    }

    .service-card-visible {
      transition: none !important;
    }

    /* No hover lift on touch */
    .service-card:hover {
      transform: none !important;
    }
  }
</style>