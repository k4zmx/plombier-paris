        <a href="tel:0189709634" class="hero-cta-call">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.85 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Appel Gratuit — 01 89 70 96 34
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 16px 100px;
    position: relative;
    z-index: 1;
  }

  .hero-card {
    background: #ffffff;
    border-radius: 24px;
    padding: 40px;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.1), 0 4px 20px rgba(0, 0, 0, 0.05);
    max-width: 1100px;
    width: 100%;
    animation: float 5s ease-in-out infinite;
  }

  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
  }

  .hero-inner {
    display: flex;
    align-items: center;
    gap: 52px;
  }

  .hero-left {
    flex: 0 0 340px;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .hero-img {
    width: 100%;
    height: 240px;
    object-fit: cover;
    border-radius: 16px;
    display: block;
  }

  .hero-badges {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .badge {
    background: #1d4ed8;
    color: white;
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 14px;
    font-family: 'Inter', Arial, sans-serif;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
  }

  .hero-content {
    flex: 1;
  }

  h1 {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: clamp(28px, 4vw, 46px);
    font-weight: 800;
    color: #0f172a;
    line-height: 1.15;
    margin-bottom: 18px;
  }

  .accent { color: #dc2626; }

  .hero-sub {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 15px;
    color: #64748b;
    line-height: 1.75;
    margin-bottom: 28px;
  }

  .trust-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-bottom: 32px;
  }

  .trust-item {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 10px;
    padding: 12px 14px;
    font-size: 13px;
    color: #334155;
    font-family: 'Inter', Arial, sans-serif;
    opacity: 0;
    animation: popIn 0.4s ease forwards;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .trust-item:nth-child(1) { animation-delay: 0.1s; }
  .trust-item:nth-child(2) { animation-delay: 0.25s; }
  .trust-item:nth-child(3) { animation-delay: 0.4s; }
  .trust-item:nth-child(4) { animation-delay: 0.55s; }
  .trust-item:nth-child(5) { animation-delay: 0.7s; }

  @keyframes popIn {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .trust-full { grid-column: 1 / -1; }

  .hero-cta-call {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    text-align: center;
    background: #dc2626;
    color: #ffffff;
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 20px;
    font-weight: 700;
    padding: 16px;
    border-radius: 12px;
    text-decoration: none;
    box-shadow: 0 8px 24px rgba(220, 38, 38, 0.3);
    transition: background-color 0.25s ease, box-shadow 0.25s ease;
  }

  .hero-cta-call:hover {
    background: #b91c1c;
    box-shadow: 0 10px 28px rgba(185, 28, 28, 0.35);
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-card { animation: none; }
    .trust-item { animation: none; opacity: 1; }
  }

  /* MOBILE */
  @media (max-width: 768px) {
    .hero {
      padding: 60px 12px 100px;
      min-height: auto;
      margin-top: -32px;
      margin-bottom: -40px;
    }

    .hero-card {
      padding: 20px 16px;
      border-radius: 20px;
      animation: none !important;
    }

    .hero-inner {
      flex-direction: column;
      gap: 20px;
    }

    .hero-left {
      flex: none;
      width: 100%;
    }

    .hero-img {
      height: 200px;
    }

    h1 {
      font-size: clamp(28px, 8vw, 38px);
    }

    .trust-grid {
      grid-template-columns: 1fr;
    }

    .trust-item {
      animation: none !important;
      opacity: 1 !important;
      transform: none !important;
      transition: none !important;
    }

    .hero-cta-call {
      font-size: 18px;
      padding: 14px;
      transition: none !important;
    }
  }
</style>
