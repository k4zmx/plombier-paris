---
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-top">
      <div class="footer-col">
        <img
          src="/logo.png"
          alt="Docteur Plomberie"
          style="height: 48px; width: auto; margin-bottom: 16px; display: block;"
        />
        <p class="footer-desc">
          Votre plombier de confiance, disponible 24h/24 et 7j/7 pour tous vos besoins en plomberie et dépannage.
        </p>
      </div>
      <div class="footer-col">
        <h3 class="footer-col-title">Liens Rapides</h3>
        <nav class="footer-nav" aria-label="Liens rapides">
          <a class="footer-link" href="/">Accueil</a>
          <a class="footer-link" href="/services">Services</a>
          <a class="footer-link" href="#avis">Avis</a>
          <a class="footer-link" href="#contact">Contact</a>
        </nav>
      </div>
      <div class="footer-col">
        <h3 class="footer-col-title">Contact</h3>
        <p class="footer-contact-line">📞 01 89 70 96 34</p>
        <p class="footer-contact-line">🕐 Disponible 24h/24 — 7j/7</p>
        <p class="footer-contact-line">🛡️ Plombier Qualifié & Assuré</p>
      </div>
    </div>
  </div>
  <div class="footer-bottom-bar">
    <p class="footer-copy">© 2026 Docteur Plomberie. Tous droits réservés.</p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 1;
    width: 100%;
    background: rgba(0, 0, 0, 0.3);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding: 60px 16px 32px;
    box-sizing: border-box;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .footer-top {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 40px;
    margin-bottom: 48px;
  }

  .footer-desc {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 13px;
    color: #94a3b8;
    line-height: 1.75;
    margin: 0;
  }

  .footer-col-title {
    font-family: 'Barlow Condensed', sans-serif;
    font-size: 18px;
    font-weight: 700;
    color: #ffffff;
    margin: 0 0 16px;
  }

  .footer-nav {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .footer-link {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 13px;
    color: #94a3b8;
    text-decoration: none;
    margin-bottom: 10px;
    transition: color 0.2s ease;
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  .footer-link:hover { color: #ffffff; }

  .footer-contact-line {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 13px;
    color: #94a3b8;
    margin: 0 0 12px;
    line-height: 1.5;
  }

  .footer-bottom-bar {
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin-left: -16px;
    margin-right: -16px;
    padding: 24px 16px 0;
    text-align: center;
  }

  .footer-copy {
    font-family: 'Inter', Arial, sans-serif;
    font-size: 12px;
    color: #64748b;
    margin: 0;
  }

  @media (max-width: 768px) {
    .site-footer {
      padding: 48px 16px 28px;
    }

    .footer-top {
      grid-template-columns: 1fr;
      gap: 32px;
      margin-bottom: 32px;
    }

    .footer-col-title {
      font-size: 16px;
      margin-bottom: 12px;
    }

    .footer-bottom-bar {
      margin-left: -16px;
      margin-right: -16px;
    }
  }
</style>
